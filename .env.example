# SafeChat Environment Variables Example
# Copy this file to .env and fill in your actual secure passwords

# MongoDB Configuration
MONGO_USERNAME=safechat_admin
MONGO_PASSWORD=your_secure_database_password
MONGO_DB_NAME=safechat_db

# Django Backend Configuration
DJANGO_SECRET_KEY=your_very_long_secure_django_secret_key_here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# React Frontend Configuration
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# SafeChat Moderation Settings
AUTO_BAN_THRESHOLD=5
